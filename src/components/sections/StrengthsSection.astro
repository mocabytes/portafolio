---
import { STRENGTHS, STRENGTH_COLUMNS } from "@data/strengths";
---

<section id="fortalezas" class="section-wrapper strengths-section">
  <div class="section-heading reveal-item">
    <h2 class="title-block">
      <span class="bracket bracket--open" aria-hidden="true">&lt;</span>
      <span class="title-main">Competencias</span>
      <span class="bracket bracket--close" aria-hidden="true">/&gt;</span>
    </h2>
  </div>

  <div class="strengths-grid">
    {
      STRENGTH_COLUMNS.map((col) => {
        const cards = STRENGTHS.filter((s) => s.column === col.id);
        return (
          <div class="strengths-column">
            <h3 class="column-heading">{col.heading}</h3>
            <div class="card-list stagger-children">
              {cards.map((card, i) => (
                <div class={`strength-card stagger-${i + 1}`}>
                  <div class="card-icon" aria-hidden="true">
                    {card.icon === "adapt" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 2L2 7l10 5 10-5-10-5z" />
                        <path d="M2 17l10 5 10-5" />
                        <path d="M2 12l10 5 10-5" />
                      </svg>
                    )}
                    {card.icon === "comfort" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                      </svg>
                    )}
                    {card.icon === "multitool" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                      </svg>
                    )}
                    {card.icon === "ai" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M12 2a4 4 0 014 4c0 1.1-.44 2.1-1.17 2.83A3.99 3.99 0 0112 10a4 4 0 01-4-4c0-1.1.44-2.1 1.17-2.83A3.99 3.99 0 0112 2z" />
                        <path d="M17 14h.01M21 10h.01M7 14h.01M3 10h.01" />
                        <path d="M8.5 18.5l1.5-4 4 2-1.5 4-4-2z" />
                        <path d="M12 22c2.5-1.5 4-4 4-7" />
                      </svg>
                    )}
                    {card.icon === "detail" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="11" cy="11" r="8" />
                        <path d="M21 21l-4.35-4.35" />
                        <path d="M11 8v6M8 11h6" />
                      </svg>
                    )}
                    {card.icon === "critical" && (
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <circle cx="12" cy="12" r="6" />
                        <circle cx="12" cy="12" r="2" />
                      </svg>
                    )}
                  </div>
                  <div class="card-body">
                    <h4 class="card-title">{card.title}</h4>
                    <p class="card-description">{card.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .strengths-section {
    flex-direction: column;
  }

  .section-heading {
    padding: 0 var(--content-padding);
  }

  /* ---- Two-column grid ---- */
  .strengths-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-8), 4vw, var(--space-16));
    max-width: 1100px;
    width: 100%;
    padding-inline: var(--content-padding);
  }

  /* ---- Column ---- */
  .strengths-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-width: 0;
  }

  .column-heading {
    font-family: var(--font-sans);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
    position: relative;
    padding-bottom: var(--space-3);
  }

  .column-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    border-radius: 1px;
  }

  /* ---- Card list ---- */
  .card-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ---- Strength Card ---- */
  .strength-card {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
    padding: var(--space-6);
    background: rgb(19 19 23 / 0.45);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--color-border-default);
    border-radius: 14px;
    position: relative;
    overflow: hidden;
    transition:
      border-color 0.3s var(--ease-out-quint),
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s var(--ease-out-quint),
      background 0.3s var(--ease-out-quint);
  }

  .strength-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 70% at 80% 20%,
      rgb(139 92 246 / 0.05) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-quint);
    pointer-events: none;
  }

  .strength-card:hover {
    border-color: rgb(139 92 246 / 0.25);
    transform: translateY(-3px);
    box-shadow:
      0 8px 30px rgb(0 0 0 / 0.35),
      0 0 40px rgb(139 92 246 / 0.04);
    background: rgb(19 19 23 / 0.6);
  }

  .strength-card:hover::before {
    opacity: 1;
  }

  /* ---- Icon ---- */
  .card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--color-accent-muted);
    color: var(--color-accent);
    transition:
      background 0.3s var(--ease-out-quint),
      color 0.3s var(--ease-out-quint),
      transform 0.3s var(--ease-spring);
  }

  .strength-card:hover .card-icon {
    background: rgb(139 92 246 / 0.2);
    color: var(--color-accent-hover);
    transform: scale(1.08);
  }

  /* ---- Body ---- */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 0.6vw + 0.7rem, 1.05rem);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.35;
  }

  .card-description {
    font-size: clamp(0.8125rem, 0.4vw + 0.7rem, 0.9375rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  @media (max-width: 860px) {
    .strengths-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
      max-width: 620px;
    }

    .column-heading {
      text-align: center;
    }

    .column-heading::after {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  @media (max-width: 480px) {
    .strengths-grid {
      padding-inline: var(--space-4);
      gap: var(--space-8);
    }

    .strength-card {
      padding: var(--space-5);
      gap: var(--space-4);
    }

    .card-icon {
      width: 38px;
      height: 38px;
      border-radius: 8px;
    }

    .card-icon svg {
      width: 20px;
      height: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .strength-card {
      transition: none;
    }
  }
</style>
